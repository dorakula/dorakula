# DORAKULA Configuration
# Copy this file to .env and adjust values

# Server
DORAKULA_HOST=0.0.0.0
DORAKULA_PORT=9092
DORAKULA_DEBUG=false

# API Authentication
DORAKULA_API_KEY=your-api-key-here

# Ollama Cloud API Integration
OLLAMA_API_KEY=your-ollama-cloud-api-key
OLLAMA_API_URL=https://ollama.com

# AI Model Tiers (free models)
OLLAMA_MODEL_QUICK=ministral-3:8b
OLLAMA_MODEL_MEDIUM=gemma3:27b
OLLAMA_MODEL_HEAVY=gemma4:31b

# Token Efficiency
AI_CACHE_TTL=3600
AI_MAX_TOKENS_QUICK=150
AI_MAX_TOKENS_MEDIUM=300
AI_MAX_TOKENS_HEAVY=500

# Paths
DORAKULA_DB_PATH=./data/dorakula.db
DORAKULA_REPORTS_DIR=./reports
